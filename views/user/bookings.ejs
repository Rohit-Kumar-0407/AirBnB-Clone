<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <main class="mx-auto max-w-5xl px-6 py-10">
        <%- include('../partials/page-header', {
            boxed: true,
            eyebrow: 'Your trips',
            heading: 'Bookings',
            description: 'Track confirmed stays, upcoming plans, and reservation details from one quiet place.',
            actionHref: '/routes/home',
            actionText: 'Explore homes'
        }) %>

        <section class="mt-6 grid gap-4 md:grid-cols-3">
            <%- include('../partials/stat-card', { label: 'Upcoming', value: '0', description: 'Trips waiting for check-in.' }) %>
            <%- include('../partials/stat-card', { label: 'Completed', value: '0', description: 'Past stays saved here.' }) %>
            <%- include('../partials/stat-card', { label: 'Pending', value: '0', description: 'Requests being reviewed.' }) %>
        </section>

        <section class="mt-6">
            <%- include('../partials/empty-state', {
                heading: 'No bookings yet',
                message: 'When you reserve a home, your booking summary will appear here with dates, host details, and price.',
                actionHref: '/routes/home',
                actionText: 'Find a stay'
            }) %>
        </section>
    </main>
</body>
</html>
