<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <% const selectedHome = typeof home !== 'undefined' ? home : ((typeof homes !== 'undefined' && homes.length > 0) ? homes[0] : null); %>
    <%- console.log(selectedHome) %>
    <% const fallbackPhoto = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=1200&q=80'; %>
    <% const detailPhoto = selectedHome && selectedHome.photourl && /^(https?:\/\/|\/)/.test(selectedHome.photourl) ? selectedHome.photourl : fallbackPhoto; %>
    <main class="mx-auto max-w-6xl px-6 py-10">
        <% if (!selectedHome) { %>
        <%- include('../partials/empty-state', {
            heading: 'No home selected',
            message: 'Choose a registered home first to view photos, host details, pricing, and reservation options.',
            actionHref: '/',
            actionText: 'Back to homes'
        }) %>
        <% } else { %>
        <section class="grid gap-6 lg:grid-cols-[1.4fr_0.8fr]">
            <div class="overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm">
                <img src="<%= detailPhoto %>" alt="<%= selectedHome.houseType %> in <%= selectedHome.location %>" onerror="this.onerror=null;this.src='<%= fallbackPhoto %>'" class="h-80 w-full object-cover">
                <div class="p-6">
                    <%- include('../partials/page-header', {
                        plain: true,
                        eyebrow: selectedHome.houseType,
                        heading: selectedHome.location,
                        description: selectedHome.description
                    }) %>
                </div>
            </div>

            <aside class="rounded-lg border border-slate-200 bg-white p-6 shadow-sm">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <p class="text-sm text-slate-500">Price per night</p>
                        <p class="mt-1 text-3xl font-bold text-slate-950">Rs. <%= selectedHome.price %></p>
                    </div>
                    <p class="rounded-md bg-rose-50 px-3 py-1 text-sm font-semibold text-rose-700"><%= selectedHome.rating %>/5</p>
                </div>
                <div class="mt-6 grid gap-3 border-t border-slate-100 pt-5 text-sm text-slate-600">
                    <p><span class="font-semibold text-slate-900">Host:</span> <%= selectedHome.name %></p>
                    <p><span class="font-semibold text-slate-900">Contact:</span> <%= selectedHome.phoneNumber %></p>
                    <p><span class="font-semibold text-slate-900">Property:</span> <%= selectedHome.houseType %></p>
                    <p><span class="font-semibold text-slate-900">Location:</span> <%= selectedHome.location %></p>
                </div>
                <a href="/reserve" class="mt-6 flex w-full justify-center rounded-md bg-rose-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200">Reserve this home</a>
                <a href="/" class="mt-3 flex w-full justify-center rounded-md border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-700 transition hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700">Back to listings</a>
            </aside>
        </section>
        <% } %>
    </main>
</body>
</html>
