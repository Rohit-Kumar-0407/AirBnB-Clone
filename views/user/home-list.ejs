<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <% const listedHomes = typeof homes !== 'undefined' ? homes : []; %>
    <main class="mx-auto max-w-6xl px-6 py-10">
        <%- include('../partials/page-header', {
            eyebrow: 'Available stays',
            heading: 'Home Listings',
            description: 'Browse registered homes with pricing, location, ratings, and host details in a compact view.',
            actionHref: '/add-home',
            actionText: 'Register home'
        }) %>

        <section class="mt-6 grid w-full gap-4 text-left sm:grid-cols-2 md:grid-cols-3">
            <% if (listedHomes.length === 0) { %>
            <%- include('../partials/empty-state', {
                heading: 'No homes registered yet',
                message: 'Once a host registers a home, it will appear here as a listing card.'
            }) %>
            <% } %>
            <% listedHomes.forEach((home) => { %>
            <%- include('../partials/home-card', {
                home: home,
                primaryHref: '/reserve',
                primaryText: 'Book now',
                secondaryHref: '/favourites',
            }) %>
            <% }); %>
        </section>
    </main>
    
</body>
</html>
