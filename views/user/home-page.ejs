<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <main class="mx-auto flex min-h-[calc(100vh-73px)] max-w-5xl flex-col items-center justify-center px-6 py-12 text-center">
        <section class="w-full rounded-lg border border-rose-100 bg-white px-6 py-12 shadow-sm">
            <h1 class="text-4xl font-bold tracking-tight text-slate-950 sm:text-6xl">Welcome To AirBnB</h1>
            <form action="/routes/add-home" class="mt-8">
                <button type="submit" class="rounded-md bg-rose-600 px-6 py-3 text-lg font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200 cursor-pointer">Register Your Home</button>
            </form>
        </section>
        <div class="mt-12 w-full text-left">
            <p class="text-sm font-semibold uppercase text-rose-600">Available stays</p>
            <h1 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl">Registered Homes</h1>
        </div>
        <section class="mt-6 grid w-full gap-4 text-left sm:grid-cols-2 md:grid-cols-3">
            <% if (homes.length === 0) { %>
            <div class="rounded-lg border border-dashed border-slate-300 bg-white p-8 text-center text-slate-600 sm:col-span-2 md:col-span-3">
                No homes registered yet.
            </div>
            <% } %>
            <% homes.forEach((home) => { %>
            <% const fallbackPhoto = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80'; %>
            <% const homePhoto = home.photo && /^(https?:\/\/|\/)/.test(home.photo) ? home.photo : fallbackPhoto; %>
            <div class="house-display-catalogs overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
                <div class="relative">
                    <img src="<%= homePhoto %>" alt="<%= home.houseType %> in <%= home.location %>" onerror="this.src='<%= fallbackPhoto %>'" class="h-32 w-full object-cover">
                    <p class="absolute left-3 top-3 rounded-md bg-white px-2.5 py-1 text-xs font-semibold text-rose-600 shadow-sm"><%= home.houseType %></p>
                </div>
                <div class="p-4">
                    <div class="flex items-start justify-between gap-3">
                        <div>
                            <p class="text-xs font-medium text-slate-500">Stay in</p>
                            <h2 class="mt-1 text-lg font-bold text-slate-950"><%= home.location %></h2>
                        </div>
                        <p class="rounded-md bg-rose-50 px-2.5 py-1 text-xs font-semibold text-rose-700"><%= home.rating %>/5</p>
                    </div>
                    <div class="mt-3 flex items-end justify-between rounded-md bg-slate-50 px-3 py-2">
                        <p class="text-xs text-slate-500">Price per night</p>
                        <p class="text-lg font-bold text-slate-950">Rs. <%= home.price %></p>
                    </div>
                    <div class="mt-3 grid gap-1.5 border-t border-slate-100 pt-3 text-xs text-slate-600">
                        <p><span class="font-semibold text-slate-900">Hosted by:</span> <%= home.ownerName %></p>
                        <p><span class="font-semibold text-slate-900">Contact:</span> <%= home.phoneNumber %></p>
                    </div>
                </div>
                <div class=" flex justify-end">
                    <a href="#" class="bg-rose-600 hover:bg-rose-700 mx-5 my-5 px-3 py-2 rounded-md text-white font-semibold transition">Book</a>
                </div>
            </div>
            <% }); %>
        </section>
    </main>
    
</body>
</html>
