<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    </header>
    <main class="mx-auto flex min-h-[calc(100vh-73px)] max-w-3xl items-center justify-center px-6 py-12">
        <section class="w-full rounded-lg border border-emerald-100 bg-white p-8 text-center shadow-sm">
            <p class="text-2xl font-bold text-slate-950">Congratulations!</p>
            <% if(editing == 'True') { %>
                <p class="mt-3 text-lg text-slate-600">Your house is now updated.</p>
            <% } else { %>
                <p class="mt-3 text-lg text-slate-600">Your house is now registered on AirBnB.</p>
            <% } %>
            
            <a href="/" class="mt-8 inline-flex rounded-md bg-rose-600 px-5 py-3 font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200">Go To HomePage</a>
        </section>
    </main>
</body>
</html>
