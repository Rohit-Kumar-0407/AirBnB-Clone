<%- include('../partials/head') %>
<body class="min-h-screen bg-slate-50 text-slate-900">
    <%- include('../partials/navbar') %>
    <% const editHome = typeof home !== 'undefined' ? home : {}; %>
    <main class="mx-auto max-w-5xl px-6 py-10">
        <%- include('../partials/page-header', {
            eyebrow: 'Host tools',
            heading: 'Edit Home',
            description: 'Update listing details so guests see accurate pricing, contact information, and stay details.'
        }) %>

        <form action="#" method="POST" class="mt-6 grid gap-6 rounded-lg border border-slate-200 bg-white p-6 shadow-sm lg:grid-cols-2">
            <div>
                <label for="ownerName" class="mb-2 block text-sm font-medium text-slate-700">Owner Name</label>
                <input id="ownerName" type="text" name="ownerName" value="<%= editHome.ownerName || '' %>" placeholder="Enter owner name" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div>
                <label for="phoneNumber" class="mb-2 block text-sm font-medium text-slate-700">Phone Number</label>
                <input id="phoneNumber" type="tel" name="phoneNumber" value="<%= editHome.phoneNumber || '' %>" placeholder="Enter phone number" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div>
                <label for="houseType" class="mb-2 block text-sm font-medium text-slate-700">House Type</label>
                <select id="houseType" name="houseType" class="w-full rounded-md border border-slate-300 bg-white px-4 py-3 text-slate-900 outline-none transition focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
                    <option value="House" <%= editHome.houseType === 'House' ? 'selected' : '' %>>House</option>
                    <option value="Apartment" <%= editHome.houseType === 'Apartment' ? 'selected' : '' %>>Apartment</option>
                    <option value="Villa" <%= editHome.houseType === 'Villa' ? 'selected' : '' %>>Villa</option>
                    <option value="Bungalow" <%= editHome.houseType === 'Bungalow' ? 'selected' : '' %>>Bungalow</option>
                </select>
            </div>
            <div>
                <label for="location" class="mb-2 block text-sm font-medium text-slate-700">Location</label>
                <input id="location" type="text" name="location" value="<%= editHome.location || '' %>" placeholder="Enter location" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div>
                <label for="rating" class="mb-2 block text-sm font-medium text-slate-700">Rating</label>
                <input id="rating" type="text" name="rating" value="<%= editHome.rating || '' %>" placeholder="Enter rating" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div>
                <label for="price" class="mb-2 block text-sm font-medium text-slate-700">Price Per Night</label>
                <input id="price" type="number" name="price" value="<%= editHome.price || '' %>" placeholder="Enter price" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div class="lg:col-span-2">
                <label for="photo" class="mb-2 block text-sm font-medium text-slate-700">Photo URL</label>
                <input id="photo" type="text" name="photo" value="<%= editHome.photo || '' %>" placeholder="Enter photo URL" class="w-full rounded-md border border-slate-300 px-4 py-3 text-slate-900 outline-none transition placeholder:text-slate-400 focus:border-rose-500 focus:ring-4 focus:ring-rose-100">
            </div>
            <div class="flex gap-3 lg:col-span-2">
                <button type="submit" class="rounded-md bg-rose-600 px-5 py-3 font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200">Save changes</button>
                <a href="/routes/home" class="rounded-md border border-slate-300 bg-white px-5 py-3 font-semibold text-slate-700 transition hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700">Cancel</a>
            </div>
        </form>
    </main>
</body>
</html>
