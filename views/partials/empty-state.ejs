<div class="rounded-lg border border-dashed border-slate-300 bg-white p-10 text-center text-slate-600 shadow-sm sm:col-span-2 md:col-span-3">
    <p class="text-lg font-bold text-slate-950"><%= heading %></p>
    <% if (typeof message !== 'undefined' && message) { %>
    <p class="mx-auto mt-2 max-w-lg text-sm"><%= message %></p>
    <% } %>
    <% if (typeof actionHref !== 'undefined' && actionHref && typeof actionText !== 'undefined' && actionText) { %>
    <a href="<%= actionHref %>" class="mt-6 inline-flex rounded-md bg-rose-600 px-5 py-3 text-sm font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200"><%= actionText %></a>
    <% } %>
</div>
