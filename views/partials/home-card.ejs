<% const cardVariant = typeof variant !== 'undefined' ? variant : 'guest'; %>
<% const fallbackPhoto = 'https://images.unsplash.com/photo-1564013799919-ab600027ffc6?auto=format&fit=crop&w=800&q=80'; %>
<% const homePhoto = home && home.photourl && /^(https?:\/\/|\/)/.test(home.photourl) ? home.photourl : fallbackPhoto; %>
<div class="house-display-catalogs overflow-hidden rounded-lg border border-slate-200 bg-white shadow-sm transition hover:-translate-y-1 hover:shadow-lg">
    <div class="relative">
        <img src="<%= homePhoto %>" alt="<%= home.houseType %> in <%= home.location %>" onerror="this.onerror=null;this.src='<%= fallbackPhoto %>'" class="h-36 w-full object-cover">
        <p class="absolute left-3 top-3 rounded-md bg-white px-2.5 py-1 text-xs font-semibold text-rose-600 shadow-sm"><%= home.houseType %></p>
        <%- include('../partials/favourites', {
                    home : home
        }) %>
        <% if (typeof badgeText !== 'undefined' && badgeText) { %>
        <p class="absolute right-3 top-3 rounded-md bg-rose-600 px-2.5 py-1 text-xs font-semibold text-white shadow-sm"><%= badgeText %></p>
        <% } %>
    </div>
    <div class="p-4">
        <div class="flex items-start justify-between gap-3">
            <div>
                <p class="text-xs font-medium <%= cardVariant === 'host' ? 'text-rose-600' : 'text-slate-500' %>"><%= cardVariant === 'host' ? home.houseType : 'Stay in' %></p>
                <h2 class="mt-1 text-lg font-bold text-slate-950"><%= home.location %></h2>
            </div>
            <% if (cardVariant === 'host') { %>
            <p class="rounded-md bg-slate-100 px-2.5 py-1 text-xs font-semibold text-slate-700">Rs. <%= home.price %></p>
            <% } else { %>
            <p class="rounded-md bg-rose-50 px-2.5 py-1 my-8 text-xs font-semibold text-rose-700"><%= home.rating %>/5</p>
            <% } %>
        </div>
        <% if (cardVariant !== 'host') { %>
        <div class="flex items-end justify-between rounded-md bg-slate-50 px-3 py-2">
            <p class="text-xs text-slate-500">Price per night</p>
            <p class="text-lg font-bold text-slate-950">Rs. <%= home.price %></p>
        </div>
        <% } %>
        <div class="mt-3 grid gap-1.5 border-t border-slate-100 pt-3 text-xs text-slate-600">
            <p><span class="font-semibold text-slate-900"><%= cardVariant === 'host' ? 'Owner:' : 'Hosted by:' %></span> <%= home.name %></p>
            <p><span class="font-semibold text-slate-900">Contact:</span> <%= home.phoneNumber %></p>
            <% if (cardVariant === 'host') { %>
            <p><span class="font-semibold text-slate-900">Rating:</span> <%= home.rating %>/5</p>
            <% } %>
        </div>
    </div>
    <% if (typeof primaryHref !== 'undefined' && primaryHref && typeof primaryText !== 'undefined' && primaryText) { %>
    <div class="flex items-center justify-between border-t border-slate-100 px-4 py-3">
        <a href="<%= primaryHref %>" class="rounded-md bg-rose-600 px-3 py-2 text-xs font-semibold text-white transition hover:bg-rose-700"><%= primaryText %></a>
        <% if (typeof secondaryHref !== 'undefined' && secondaryHref && typeof secondaryText !== 'undefined' && secondaryText) { %>
        <a href="<%= secondaryHref %>" class="text-xs font-semibold text-red-500 transition hover:text-red-700"><%= secondaryText %></a>
        <% } %>
        <% if (typeof tertiaryHref !== 'undefined' && tertiaryHref && typeof tertiaryText !== 'undefined' && tertiaryText) { %>
        <form action="<%= tertiaryHref %>" method="POST">
            <button type="submit" class="text-xs font-semibold text-red-500 transition hover:text-red-700 cursor-pointer"><%= tertiaryText %></button>
        </form>
        <% } %>
    </div>
    <% } %>
</div>
