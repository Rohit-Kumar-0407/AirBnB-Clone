<section class="<%= (typeof plain !== 'undefined' && plain) ? '' : ((typeof boxed !== 'undefined' && boxed) ? 'rounded-lg border border-slate-200 bg-white p-6 shadow-sm' : 'border-b border-slate-200 pb-6') %>">
    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <p class="text-sm font-semibold uppercase text-rose-600"><%= eyebrow %></p>
            <h1 class="mt-2 text-3xl font-bold text-slate-950 sm:text-4xl"><%= heading %></h1>
            <% if (typeof description !== 'undefined' && description) { %>
            <p class="mt-2 max-w-2xl text-sm text-slate-600"><%= description %></p>
            <% } %>
        </div>
        <% if (typeof actionHref !== 'undefined' && actionHref && typeof actionText !== 'undefined' && actionText) { %>
        <a href="<%= actionHref %>" class="<%= (typeof actionVariant !== 'undefined' && actionVariant === 'secondary') ? 'inline-flex rounded-md border border-slate-300 bg-white px-4 py-2.5 text-sm font-semibold text-slate-700 transition hover:border-rose-200 hover:bg-rose-50 hover:text-rose-700' : 'inline-flex rounded-md bg-rose-600 px-4 py-2.5 text-sm font-semibold text-white transition hover:bg-rose-700 focus:outline-none focus:ring-4 focus:ring-rose-200' %>"><%= actionText %></a>
        <% } %>
    </div>
</section>
